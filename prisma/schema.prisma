generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int            @id @default(autoincrement())
  email              String         @unique
  password           String
  name               String
  beeminderUsername   String?
  beeminderAuthToken String?
  beeminderGoalSlug  String?
  smsPhone           String?
  smsEnabled         Boolean        @default(false)
  smsOptedOutAt      DateTime?
  smsTimezone        String?
  smsReminderHour    Int?
  smsLastSentAt      DateTime?
  hats               Hat[]
  sessions           FocusSession[]
  passwordResets     PasswordReset[]
  createdAt          DateTime       @default(now())
}

model Hat {
  id        Int            @id @default(autoincrement())
  name      String
  done      Boolean        @default(false)
  doneAt    DateTime?
  deletedAt DateTime?
  user      User           @relation(fields: [userId], references: [id])
  userId    Int
  sessions  FocusSession[]
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model FocusSession {
  id              Int      @id @default(autoincrement())
  durationSeconds Int
  score           Int
  hat             Hat      @relation(fields: [hatId], references: [id])
  hatId           Int
  user            User     @relation(fields: [userId], references: [id])
  userId          Int
  createdAt       DateTime @default(now())
}
